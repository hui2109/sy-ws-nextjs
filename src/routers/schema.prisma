// ============================================================
// schema.prisma — 由 SQLModel (models.py + utils.py) 转换而来
// 数据库: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 枚举 Bans（对应 utils.Bans）
//
// 规则说明：
//   • 数字开头的值 → Prisma 标识符加 _ 前缀，@map 还原原始值
//   • 含连字符    → 改为下划线，@map 还原（S2_A → "S2-A"）
//   • 中文值      → 保留英文缩写，@map 存储中文（如 RL → "放射假"）
//   • 大小写不同  → 统一大写，@map 还原（PHY → "Phy"）
// ============================================================
enum Bans {
  NA

// 日班系列
_1A @map("1A")
_2A @map("2A")
_3A @map("3A")
_1B @map("1B")
_2B @map("2B")
_3B @map("3B")
_1C @map("1C")
_2C @map("2C")
_3C @map("3C")

// S 班系列
S1
S2
S2_A @map("S2-A")
S2_B @map("S2-B")

// N 班系列
N1
N2

// 特殊工作
ENGAGE @map("进修")
TRAIN  @map("培训")
JD     @map("机动")

// 休假类
RELAX  @map("休息")
RL     @map("放射假")  // Radiation Leave
AL     @map("年假")    // Annual Leave
SICK   @map("病假")
EVENT  @map("事假")
MARRY  @map("婚假")
ML     @map("产假")    // Maternity Leave
PL     @map("陪产假")  // Paternity Leave
CL     @map("育儿假")  // Childcare Leave
FL     @map("丧假")    // Funeral Leave
DL     @map("补假")    // Deferred Leave
LL     @map("调休假")  // Lieu Leave
OTHERS @map("其他假")

// 加班系列
OAE
OBE
OCE
OAF
OBF
OCF

// 实习班系列
T1A
T1B
T2A
T2B
T3A
T3B
TS1
TS2
PHY @map("Phy")
}

// ============================================================
// 枚举 ScheduleStatus（对应 utils.ScheduleStatus）
// 原始值为中文，@map 保留数据库实际存储值
// ============================================================
enum ScheduleStatus {
  PUBLISHED      @map("已发布")
  PENDING_REVIEW @map("待审核") // 原 Python 名: PendingReview
  DRAFT          @map("草稿")
}

// ============================================================
// Account — 账户
// 与 Personnel 一对一（Personnel 持有外键）
// ============================================================
model Account {
  id       Int     @id @default(autoincrement())
  username String
  password String
  avatar   String? @default("/WSFrontends/assets/img/avatars/001-pirate.svg")

  personnel Personnel?

  @@map("account")
}

// ============================================================
// Bantype — 班种
// 与 Workschedule、RestInfo、ReserveVacation 均为一对多
// ============================================================
model Bantype {
  id          Int      @id @default(autoincrement())
  ban         Bans
  startTime   DateTime @db.Time(6)
  endTime     DateTime @db.Time(6)
  description String?

  workschedules    Workschedule[]
  restInfos        RestInfo[]
  reserveVacations ReserveVacation[]

  @@map("bantype")
}

// ============================================================
// Personnel — 员工
//   - 与 Account        一对一（持有外键 accountId）
//   - 与 RestInfo       一对多
//   - 与 ReserveVacation 一对多
//   - 与 Workschedule   多对多（通过 WorkschedulePersonnelLink）
// ============================================================
model Personnel {
  id          Int      @id @default(autoincrement())
  name        String
  weight      Float    @default(1.0)
  hiredate    DateTime @db.Date
  worknumber  String
  phonenumber String
  accountId   Int?     @unique

  account           Account?                    @relation(fields: [accountId], references: [id])
  restInfos         RestInfo[]
  reserveVacations  ReserveVacation[]
  workscheduleLinks WorkschedulePersonnelLink[]

  @@index([name])
  @@index([weight])
  @@map("personnel")
}

// ============================================================
// WorkschedulePersonnelLink — 排班 ↔ 员工 多对多中间表
// ============================================================
model WorkschedulePersonnelLink {
  workscheduleId Int
  personnelId    Int

  workschedule Workschedule @relation(fields: [workscheduleId], references: [id], onDelete: Cascade)
  personnel    Personnel    @relation(fields: [personnelId], references: [id], onDelete: Cascade)

  @@id([workscheduleId, personnelId])
  @@map("workschedule_personnel_link")
}

// ============================================================
// Workschedule — 排班表
//   - 与 Bantype    多对一
//   - 与 Personnel  多对多（通过中间表）
// ============================================================
model Workschedule {
  id        Int            @id @default(autoincrement())
  workDate  DateTime       @db.Date
  bantypeId Int?
  status    ScheduleStatus @default(DRAFT)

  bantype        Bantype?                    @relation(fields: [bantypeId], references: [id])
  personnelLinks WorkschedulePersonnelLink[]

  @@index([workDate])
  @@index([status])
  @@map("workschedule")
}

// ============================================================
// RestInfo — 休息日
//   - 与 Personnel  多对一
//   - 与 Bantype    多对一
//   - isDeleted     软删除标记（0=有效，1=已删除）
// ============================================================
model RestInfo {
  id            Int      @id @default(autoincrement())
  startDate     DateTime @db.Date
  endDate       DateTime @db.Date
  availableDays Int
  personnelId   Int?
  bantypeId     Int?
  isDeleted     Int?     @default(0)

  personnel Personnel? @relation(fields: [personnelId], references: [id])
  bantype   Bantype?   @relation(fields: [bantypeId], references: [id])

  @@index([startDate])
  @@index([endDate])
  @@map("restinfo")
}

// ============================================================
// ReserveVacation — 预约排班
//   - 与 Bantype    多对一
//   - 与 Personnel  多对一
// ============================================================
model ReserveVacation {
  id          Int      @id @default(autoincrement())
  sequence    Int
  reserveDate DateTime @db.Date
  bantypeId   Int?
  personnelId Int?

  bantype   Bantype?   @relation(fields: [bantypeId], references: [id])
  personnel Personnel? @relation(fields: [personnelId], references: [id])

  @@index([sequence])
  @@index([reserveDate])
  @@map("reservevacation")
}
